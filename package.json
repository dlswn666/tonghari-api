{
  "name": "tonghari-api",
  "version": "1.0.0",
  "description": "통하리 API 서버 - 고정 IP로 외부 API 연동",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "node --import tsx --test tests/*.test.ts",
    "phase0-s:gate": "tsx scripts/phase0-s-gate.ts",
    "start": "node dist/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop tonghari-api",
    "pm2:restart": "pm2 restart tonghari-api",
    "pm2:logs": "pm2 logs tonghari-api",
    "docker:build": "docker build --build-arg GIT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo unknown) --build-arg BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) --build-arg IMAGE_TAG=alimtalk-proxy:local -t alimtalk-proxy .",
    "docker:run": "docker run -d -p 3100:3100 --env-file .env --name alimtalk-proxy alimtalk-proxy",
    "docker:stop": "docker stop alimtalk-proxy && docker rm alimtalk-proxy",
    "docker:logs": "docker logs -f alimtalk-proxy",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "iconv-lite": "^0.7.1",
    "jsonwebtoken": "^9.0.2",
    "p-queue": "^8.0.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.20.1",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
