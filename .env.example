NODE_ENV=development
PORT=3100

# 운영 Web -> API 서명 및 운영 Supabase
JWT_SECRET=replace-with-production-api-jwt-secret
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-production-service-role-key

# 개발 Web -> 동일 API 서명 및 개발 Supabase
# 세 값은 모두 함께 설정해야 하며 개발 서명키/URL은 운영 값과 달라야 합니다.
DEV_API_JWT_SECRET=replace-with-development-api-jwt-secret
DEV_SUPABASE_URL=https://your-development-project.supabase.co
DEV_SUPABASE_SERVICE_ROLE_KEY=replace-with-development-service-role-key
# W1이 적용된 DB target만 쉼표로 명시합니다. 운영 W1 적용 전에는 development만 허용합니다.
BUILDING_WRITE_OPERATION_TARGETS=development

ALIGO_API_KEY=replace-with-aligo-api-key
ALIGO_USER_ID=replace-with-aligo-user-id
ALIGO_SENDER_PHONE=replace-with-sender-phone
DEFAULT_SENDER_KEY=replace-with-default-sender-key
DEFAULT_CHANNEL_NAME=통하리

QUEUE_CONCURRENCY=5
QUEUE_MAX_SIZE=100

VWORLD_API_KEY=
VWORLD_API_DOMAIN=www.tonghari.kr
VWORLD_ATTR_REQUEST_INTERVAL_MS=300
DATA_PORTAL_API_KEY=
# 운영 canary 대상 allowlist가 별도 구현·승인되기 전까지 반드시 false를 유지합니다.
LAND_AREA_SYNC_ENABLED=false
# databaseTarget:unionUuid:anchorPnu 형식. 여러 PNU는 쉼표로 구분하며 wildcard는 금지합니다.
LAND_AREA_SYNC_ALLOWED_TARGETS=

KG_INICIS_MID=
KG_INICIS_API_KEY=
KG_INICIS_ALLOWED_HOSTS=
